{
  "name": "@lowlysre/icd-10-cm",
  "version": "1.1.5",
  "description": "ICD-10-CM (Clinical Modification) data for use in the US healthcare system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "test": "npm run build --silent && node --test",
    "lint": "eslint . --ext .ts",
    "build": "tsup src/index.ts --format esm,cjs --minify --treeshake --clean && tsc --emitDeclarationOnly --project tsconfig.json --outDir dist --rootDir src",
    "parse-icd": "node --experimental-strip-types scripts/parseICD.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "author": "John McCall",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest"
  },
  "repository": {
    "url": "https://github.com/lowlysre/icd-10-cm"
  },
  "keywords": [
    "icd",
    "icd-10",
    "icd-code",
    "icd10",
    "icd-10-cm",
    "medical",
    "healthcare",
    "diagnosis",
    "who"
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "prettier": "^3.3.2",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3"
  }
}
