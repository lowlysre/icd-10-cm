{
  "name": "@lowlysre/icd-10-cm",
  "version": "2.0.0",
  "description": "ICD-10-CM (Clinical Modification) data for use in the US healthcare system",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "scripts": {
    "test": "npm run build --silent && node --test",
    "lint": "oxlint . && prettier --check .",
    "prebuild": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc --project tsconfig.json",
    "parse-icd": "node --experimental-strip-types scripts/parseICD.ts",
    "test:coverage": "npm run build --silent && node --test --experimental-test-coverage --test-coverage-include=\"dist/**\" --test-coverage-lines=100 --test-coverage-branches=100 --test-coverage-functions=100"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "author": "John McCall",
  "license": "MIT",
  "files": [
    "dist",
    "data"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "tag": "latest"
  },
  "repository": {
    "url": "https://github.com/lowlysre/icd-10-cm"
  },
  "keywords": [
    "icd",
    "icd-10",
    "icd-code",
    "icd10",
    "icd-10-cm",
    "medical",
    "healthcare",
    "diagnosis",
    "who"
  ],
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxlint": "^1.0.0",
    "prettier": "^3.3.2",
    "typescript": "^7.0.2"
  }
}
